{
    "name": "@jump-slasher/client",
    "version": "1.3.0",
    "description": "Jump Slasher game client — Phaser 3 + TypeScript, bundled with Vite.",
    "private": true,
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "vite --config vite/config.dev.mjs",
        "build": "vite build --config vite/config.prod.mjs",
        "preview": "vite preview --config vite/config.prod.mjs",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@jump-slasher/shared": "*",
        "phaser": "^3.90.0",
        "socket.io-client": "^4.8.3",
        "terser": "^5.31.0",
        "vite": "^6.3.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.20",
        "typescript": "~5.7.2"
    }
}
