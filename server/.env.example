# Скопируй этот файл в .env и заполни значения

# Строка подключения к PostgreSQL
# Локально: postgres://user:password@localhost:5432/jump_slasher
# Render/Railway: вставь URL из дашборда БД
DATABASE_URL=postgres://user:password@localhost:5432/jump_slasher

# Секрет для подписи JWT — замени на любую длинную случайную строку
JWT_SECRET=replace_with_random_secret_min_32_chars

# Порт сервера (Render/Railway подставят автоматически)
PORT=3000

# CORS — адрес фронтенда (в dev — localhost:5173, в prod — домен сайта)
CLIENT_ORIGIN=http://localhost:5173
