{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "preserve",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node"],
        "strict": false
    },
    "include": ["*.js"]
}
